        <widget class="QLabel" name="serverSettingsStatusLabel">
         <property name="styleSheet">
          <string notr="true">font-size: 11px; padding: 1px 2px;</string>
         </property>
         <property name="text">
          <string/>
         </property>
        </widget>
       </item>
      </layout>
     </widget>
     <!-- === NEW: Graphics Presets Tab === -->
     <widget class="QWidget" name="graphicsPresetsTab">
      <attribute name="title">
       <string>Graphics Presets</string>
      </attribute>
      <layout class="QVBoxLayout" name="graphicsPresetsTabLayout">
       <property name="spacing"><number>10</number></property>
       <property name="leftMargin"><number>12</number></property>
       <property name="topMargin"><number>12</number></property>
       <property name="rightMargin"><number>12</number></property>
       <property name="bottomMargin"><number>12</number></property>

       <!-- Preset buttons group -->
       <item>
        <widget class="QGroupBox" name="graphicsPresetGroupBox">
         <property name="title"><string>Quality preset</string></property>
         <layout class="QHBoxLayout" name="graphicsPresetLayout">
          <property name="spacing"><number>8</number></property>
          <item>
           <widget class="QPushButton" name="presetLowButton">
            <property name="text"><string>Low</string></property>
            <property name="minimumHeight"><number>44</number></property>
            <property name="checkable"><bool>true</bool></property>
            <property name="styleSheet">
             <string notr="true">QPushButton { font-size: 12pt; font-weight: 600; border-radius: 4px; }
QPushButton:checked { background: #2e7d32; color: white; border: 2px solid #1b5e20; }</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="presetMediumButton">
            <property name="text"><string>Medium</string></property>
            <property name="minimumHeight"><number>44</number></property>
            <property name="checkable"><bool>true</bool></property>
            <property name="styleSheet">
             <string notr="true">QPushButton { font-size: 12pt; font-weight: 600; border-radius: 4px; }
QPushButton:checked { background: #1565c0; color: white; border: 2px solid #0d47a1; }</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="presetHighButton">
            <property name="text"><string>High</string></property>
            <property name="minimumHeight"><number>44</number></property>
            <property name="checkable"><bool>true</bool></property>
            <property name="styleSheet">
             <string notr="true">QPushButton { font-size: 12pt; font-weight: 600; border-radius: 4px; }
QPushButton:checked { background: #6a1b9a; color: white; border: 2px solid #4a148c; }</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="presetUltraButton">
            <property name="text"><string>Ultra</string></property>
            <property name="minimumHeight"><number>44</number></property>
            <property name="checkable"><bool>true</bool></property>
            <property name="styleSheet">
             <string notr="true">QPushButton { font-size: 12pt; font-weight: 600; border-radius: 4px; }
QPushButton:checked { background: #b71c1c; color: white; border: 2px solid #7f0000; }</string>
            </property>
           </widget>
          </item>
         </layout>
        </widget>
       </item>

       <!-- Two-column detail settings -->
       <item>
        <layout class="QHBoxLayout" name="graphicsDetailColumnsLayout">
         <property name="spacing"><number>10</number></property>

         <!-- Left column -->
         <item>
          <layout class="QVBoxLayout" name="graphicsLeftColumnLayout">
           <property name="spacing"><number>8</number></property>

           <item>
            <widget class="QGroupBox" name="renderingGroupBox">
             <property name="title"><string>Rendering</string></property>
             <layout class="QFormLayout" name="renderingFormLayout">
              <property name="horizontalSpacing"><number>12</number></property>
              <property name="verticalSpacing"><number>6</number></property>
              <item row="0" column="0"><widget class="QLabel" name="label_renderDistance"><property name="text"><string>View distance</string></property></widget></item>
              <item row="0" column="1">
               <widget class="QSlider" name="viewDistanceSlider">
                <property name="orientation"><enum>Qt::Horizontal</enum></property>
                <property name="minimum"><number>1000</number></property>
                <property name="maximum"><number>100000</number></property>
                <property name="singleStep"><number>1000</number></property>
               </widget>
              </item>
              <item row="1" column="0"><widget class="QLabel" name="label_viewDistanceValue"><property name="text"><string>–</string></property></widget></item>
              <item row="1" column="1"><spacer name="sp1"><property name="orientation"><enum>Qt::Horizontal</enum></property><property name="sizeHint" stdset="0"><size><width>0</width><height>0</height></size></property></spacer></item>
              <item row="2" column="0"><widget class="QLabel" name="label_textureFilter"><property name="text"><string>Texture filter</string></property></widget></item>
              <item row="2" column="1">
               <widget class="QComboBox" name="textureFilterComboBox">
                <item><property name="text"><string>Nearest</string></property><property name="userData" stdset="0"><string>nearest</string></property></item>
                <item><property name="text"><string>Bilinear</string></property><property name="userData" stdset="0"><string>linear</string></property></item>
                <item><property name="text"><string>Trilinear</string></property><property name="userData" stdset="0"><string>trilinear</string></property></item>
               </widget>
              </item>
              <item row="3" column="0"><widget class="QLabel" name="label_anisotropy"><property name="text"><string>Anisotropic filter</string></property></widget></item>
              <item row="3" column="1">
               <widget name="anisotropySpinBox" class="QSpinBox">
                <property name="minimum"><number>1</number></property>
                <property name="maximum"><number>16</number></property>
               </widget>
              </item>
             </layout>
            </widget>
           </item>

           <item>
            <widget class="QGroupBox" name="shadowsGroupBox">
             <property name="title"><string>Shadows</string></property>
             <layout class="QFormLayout" name="shadowsFormLayout">
              <property name="horizontalSpacing"><number>12</number></property>
              <property name="verticalSpacing"><number>6</number></property>
              <item row="0" column="0"><widget class="QLabel" name="label_shadows"><property name="text"><string>Enable shadows</string></property></widget></item>
              <item row="0" column="1"><widget class="QCheckBox" name="shadowsCheckBox"><property name="text"><string/></property></widget></item>
              <item row="1" column="0"><widget class="QLabel" name="label_shadowRes"><property name="text"><string>Shadow map size</string></property></widget></item>
              <item row="1" column="1">
               <widget class="QComboBox" name="shadowResComboBox">
                <item><property name="text"><string>512</string></property><property name="userData" stdset="0"><string>512</string></property></item>
                <item><property name="text"><string>1024</string></property><property name="userData" stdset="0"><string>1024</string></property></item>
                <item><property name="text"><string>2048</string></property><property name="userData" stdset="0"><string>2048</string></property></item>
                <item><property name="text"><string>4096</string></property><property name="userData" stdset="0"><string>4096</string></property></item>
               </widget>
              </item>
              <item row="2" column="0"><widget class="QLabel" name="label_actorShadows"><property name="text"><string>Actor shadows</string></property></widget></item>
              <item row="2" column="1"><widget class="QCheckBox" name="actorShadowsCheckBox"><property name="text"><string/></property></widget></item>
              <item row="3" column="0"><widget class="QLabel" name="label_terrainShadows"><property name="text"><string>Terrain shadows</string></property></widget></item>
              <item row="3" column="1"><widget class="QCheckBox" name="terrainShadowsCheckBox"><property name="text"><string/></property></widget></item>
             </layout>
            </widget>
           </item>

          </layout>
         </item>

         <!-- Right column -->
         <item>
          <layout class="QVBoxLayout" name="graphicsRightColumnLayout">
           <property name="spacing"><number>8</number></property>

           <item>
            <widget class="QGroupBox" name="waterGroupBox">
             <property name="title"><string>Water and sky</string></property>
             <layout class="QFormLayout" name="waterFormLayout">
              <property name="horizontalSpacing"><number>12</number></property>
              <property name="verticalSpacing"><number>6</number></property>
              <item row="0" column="0"><widget class="QLabel" name="label_waterShader"><property name="text"><string>Water shader</string></property></widget></item>
              <item row="0" column="1"><widget class="QCheckBox" name="waterShaderCheckBox"><property name="text"><string/></property></widget></item>
              <item row="1" column="0"><widget class="QLabel" name="label_waterReflection"><property name="text"><string>Water reflection</string></property></widget></item>
              <item row="1" column="1">
               <widget class="QComboBox" name="waterReflectionComboBox">
                <item><property name="text"><string>Disabled</string></property><property name="userData" stdset="0"><string>0</string></property></item>
                <item><property name="text"><string>Low</string></property><property name="userData" stdset="0"><string>1</string></property></item>
                <item><property name="text"><string>Medium</string></property><property name="userData" stdset="0"><string>2</string></property></item>
                <item><property name="text"><string>High</string></property><property name="userData" stdset="0"><string>3</string></property></item>
               </widget>
              </item>
              <item row="2" column="0"><widget class="QLabel" name="label_fog"><property name="text"><string>Use distance fog</string></property></widget></item>
              <item row="2" column="1"><widget class="QCheckBox" name="fogCheckBox"><property name="text"><string/></property></widget></item>
              <item row="3" column="0"><widget class="QLabel" name="label_radialFog"><property name="text"><string>Radial fog</string></property></widget></item>
              <item row="3" column="1"><widget class="QCheckBox" name="radialFogCheckBox"><property name="text"><string/></property></widget></item>
             </layout>
            </widget>
           </item>

           <item>
            <widget class="QGroupBox" name="lightingGroupBox">
             <property name="title"><string>Lighting</string></property>
             <layout class="QFormLayout" name="lightingFormLayout">
              <property name="horizontalSpacing"><number>12</number></property>
              <property name="verticalSpacing"><number>6</number></property>
              <item row="0" column="0"><widget class="QLabel" name="label_lightingMode"><property name="text"><string>Lighting method</string></property></widget></item>
              <item row="0" column="1">
               <widget class="QComboBox" name="lightingModeComboBox">
                <item><property name="text"><string>Legacy</string></property><property name="userData" stdset="0"><string>legacy</string></property></item>
                <item><property name="text"><string>Shaders</string></property><property name="userData" stdset="0"><string>shaders compatibility</string></property></item>
                <item><property name="text"><string>Shaders (instanced)</string></property><property name="userData" stdset="0"><string>shaders</string></property></item>
               </widget>
              </item>
              <item row="1" column="0"><widget class="QLabel" name="label_maxLights"><property name="text"><string>Max lights per object</string></property></widget></item>
              <item row="1" column="1">
               <widget name="maxLightsSpinBox" class="QSpinBox">
                <property name="minimum"><number>1</number></property>
                <property name="maximum"><number>64</number></property>
               </widget>
              </item>
              <item row="2" column="0"><widget class="QLabel" name="label_bloom"><property name="text"><string>Bloom / postprocess</string></property></widget></item>
              <item row="2" column="1"><widget class="QCheckBox" name="bloomCheckBox"><property name="text"><string/></property></widget></item>
              <item row="3" column="0"><widget class="QLabel" name="label_sunlight"><property name="text"><string>Sunlight scattering</string></property></widget></item>
              <item row="3" column="1"><widget class="QCheckBox" name="sunlightScatteringCheckBox"><property name="text"><string/></property></widget></item>
             </layout>
            </widget>
           </item>

          </layout>
         </item>

        </layout>
       </item>

       <!-- Action buttons for graphics presets -->
       <item>
        <layout class="QHBoxLayout" name="graphicsPresetActionLayout">
         <item>
          <widget class="QPushButton" name="applyGraphicsPresetButton">
           <property name="text"><string>Apply preset to settings.cfg</string></property>
           <property name="minimumHeight"><number>32</number></property>
          </widget>
         </item>
         <item>
          <widget class="QPushButton" name="saveGraphicsPresetButton">
           <property name="text"><string>Save current as preset…</string></property>
           <property name="minimumHeight"><number>32</number></property>
          </widget>
         </item>
         <item>
          <spacer name="graphicsPresetSpacer">
           <property name="orientation"><enum>Qt::Horizontal</enum></property>
           <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
          </spacer>
         </item>
         <item>
          <widget class="QLabel" name="graphicsPresetStatusLabel">
           <property name="styleSheet">
            <string notr="true">font-size: 11px; color: palette(mid);</string>
           </property>
           <property name="text"><string/></property>
          </widget>
         </item>
        </layout>
       </item>

      </layout>
     </widget>
    </widget>
   </item>
  </layout>
 </widget>
 <resources/>
 <connections/>
</ui>
