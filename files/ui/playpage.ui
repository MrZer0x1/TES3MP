            <property name="styleSheet">
             <string notr="true">#playButton, #serverButton {
    height: 50px;
    margin-bottom: 16px;
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:0, y2:1,
        stop:0 rgba(255,255,255,200), stop:0.1 rgba(255,255,255,15),
        stop:0.49 rgba(255,255,255,75), stop:0.5 rgba(0,0,0,0),
        stop:0.9 rgba(0,0,0,55), stop:1 rgba(0,0,0,100));
    font-size: 18pt; color: black;
    border-right: 1px solid rgba(0,0,0,155);
    border-left:  1px solid rgba(0,0,0,55);
    border-top:   1px solid rgba(0,0,0,55);
    border-bottom:1px solid rgba(0,0,0,155);
    border-radius: 5px;
}
#playButton:hover, #serverButton:hover { border: 2px solid rgba(164,192,228,255); }
#playButton:pressed, #serverButton:pressed {
    background: qlineargradient(x1:0,y1:0,x2:0,y2:1,
        stop:0 rgba(0,0,0,75), stop:0.1 rgba(0,0,0,15),
        stop:0.2 rgba(255,255,255,55), stop:1 rgba(255,255,255,155));
    border: 1px solid rgba(0,0,0,55);
}</string>
